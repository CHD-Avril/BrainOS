# Copy this file to .env only for local development. Never commit real credentials.
# Empty values intentionally fall back to the development-only Compose defaults.
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=

# Required when running the backend with any profile other than dev.
BRAINOS_ADMIN_PASSWORD=
BRAINOS_JWT_SECRET=
BRAINOS_STORAGE_PATH=./data/uploads

# Chroma Cloud: copy all four values from the Cloud database connection page.
# Keep CHROMA_URL=http://localhost:8000 and the default tenant/database for local Chroma.
CHROMA_URL=http://localhost:8000
CHROMA_API_KEY=
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database

# Required for document embeddings and the default Qwen chat model.
QWEN_API_KEY=

# Required only when a conversation selects DeepSeek.
DEEPSEEK_API_KEY=
